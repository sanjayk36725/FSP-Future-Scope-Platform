# FSP Platform Backend Configuration

# Environment
ENVIRONMENT=development
DEBUG=True

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=sqlite:///./fsp.db
# For PostgreSQL: postgresql://username:password@localhost:5432/fsp_db

# JWT
SECRET_KEY=your-super-secret-key-change-in-production-please-change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Email Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
ADMIN_EMAIL=admin@fspplatform.com

# AI Configuration
GOOGLE_API_KEY=your-google-api-key
OPENAI_API_KEY=your-openai-api-key

# Redis
REDIS_URL=redis://localhost:6379

# File Upload
MAX_FILE_SIZE=52428800
UPLOAD_DIR=uploads
